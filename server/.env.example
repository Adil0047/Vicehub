# ==========================================
# ViceHub Server — Environment Variables
# ==========================================
# Copy this file to .env.development (local dev) or .env.production
# (production deploy) and fill in real values. Never commit actual
# secrets — only this template is tracked in Git.

# --- App ---
# development | production
NODE_ENV=development

# Port the Express server listens on
PORT=5000

# Origin allowed by CORS — must match the client's deployed/dev URL
CLIENT_URL=http://localhost:5173

# --- Database (Phase 2) ---
# MongoDB Atlas connection string. Get this from Atlas > Connect > Drivers.
# Replace <username>, <password>, and <cluster-url> with real values.
# Include the database name after the host, e.g. /vicehub
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/vicehub?retryWrites=true&w=majority

# --- Authentication (Phase 2) ---
# Long, random, unguessable string used to sign JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# How long an access token stays valid before re-login is required.
# Examples: 15m, 1h, 7d
JWT_EXPIRES_IN=7d

# --- Image Storage (Phase 4 — not yet used) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
